apiVersion: v1
kind: ServiceAccount
metadata:
  name: custom-scaler
  namespace: {{ namespace_name }}

---

apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: custom-scaler-{{ namespace_name }}
rules:
  - apiGroups: ["apps"]
    resources: ["deployments"]
    verbs: ["get", "patch"]
  - apiGroups: [""]
    resources: ["pods"]
    verbs: ["list"]

---

apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: custom-scaler-{{ namespace_name }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: custom-scaler-{{ namespace_name }}
subjects:
  - kind: ServiceAccount
    name: custom-scaler
    namespace: {{ namespace_name }}
